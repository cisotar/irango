# Resolução de dependências loose (peer deps).
#
# O projeto tem um conflito de peer dependency conhecido (knip →
# @eslint-community/eslint-utils) e versões divergentes de @swc/helpers
# (next fixa 0.5.15, @swc/core via @serwist/turbopack exige >=0.5.17).
# O package-lock.json é gerado com legacy-peer-deps; sem este flag, o
# `npm ci` do CI (npm estrito) rejeita o lock pedindo @swc/helpers@0.5.23
# e webpack nested. Este .npmrc faz o `npm ci` consumir o lock no mesmo
# modo em que foi gerado — instalação determinística e consistente.
legacy-peer-deps=true
