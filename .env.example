# Supabase — copie para .env.local e preencha com as chaves do seu projeto
# Painel: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-public-key
# Chave admin (ignora RLS) — NUNCA exponha no client nem commite
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Segredo do webhook Hotmart (hottok) — valida autenticidade dos eventos de
# assinatura. SERVER-ONLY: nunca use prefixo NEXT_PUBLIC_, nunca commite o valor real.
HOTMART_WEBHOOK_TOKEN=seu-hottok-do-painel-hotmart

# Sentry (observabilidade) — issue 061
# DSN é público e pode ir para o client. Ausente em dev local = Sentry desligado
# (o app NÃO quebra sem ele).
NEXT_PUBLIC_SENTRY_DSN=
# Upload de source maps no build de produção/CI. SECRETO: nunca commite o valor.
# Ausente = build não tenta subir source maps (silencioso).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Upstash Redis — rate limit por IP nas Server Actions sensíveis (issue 052).
# SERVER-ONLY: nunca use prefixo NEXT_PUBLIC_ (seguranca.md §7), nunca commite os
# valores reais. Ausentes em dev local = rate limit DESATIVADO (fail-open); o app
# roda normalmente. Painel: console.upstash.com → seu banco Redis → REST API.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Nominatim (OpenStreetMap) — User-Agent identificado do iRango para geocoding
# CEP/endereço → coords (issue 003). A política de uso do OSM EXIGE um User-Agent
# identificável (com contato); requisições sem ele são banidas. SERVER-ONLY: nunca
# use prefixo NEXT_PUBLIC_ (seguranca.md §7), nunca commite o valor real. Ausente =
# geocoding por raio DESATIVADO (fail-closed); o app não quebra. Ex.:
# "iRango/1.0 (+https://seu-dominio; contato@seu-dominio)".
NOMINATIM_USER_AGENT=

# Google OAuth — login social com Google (issue 001). Credenciais "Web application"
# do Google Cloud Console, lidas pelo Supabase Auth via env(...) no config.toml.
# SERVER-ONLY: nunca use prefixo NEXT_PUBLIC_ (seguranca.md §7), nunca commite os
# valores reais. O client só conhece provider: "google", jamais estas credenciais.
# Em produção, configure também no Dashboard do Supabase + Google Cloud Console.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# Billing por assinatura própria (Asaas — issues 076/077/078). SERVER-ONLY: nunca
# use prefixo NEXT_PUBLIC_ (seguranca.md §7), nunca commite os valores reais. Dados
# de cartão NUNCA passam pelo nosso servidor (RN-11).
# BILLING_PROVIDER seleciona o adapter ativo (getBillingProvider). 'asaas' = DA-1.
BILLING_PROVIDER=asaas
# Chave da API Asaas (access_token) — cria/troca/cancela assinatura (078).
ASAAS_API_KEY=
# Base da API Asaas — sandbox vs produção (078). Default = sandbox se ausente.
# Produção: https://api.asaas.com/v3
ASAAS_API_BASE_URL=https://sandbox.asaas.com/api/v3
# Token estático do webhook Asaas (header asaas-access-token) — valida a
# autenticidade dos eventos antes de qualquer efeito (gate 401, 077).
ASAAS_WEBHOOK_TOKEN=

# Admin do SaaS (issue 080) — UUID (auth.uid) do ÚNICO dono autorizado a conceder/
# revogar cortesia, suspender e reativar lojas (RN-13, sem tabela de admins). É a
# única via não-webhook que escreve assinatura_status; se contornável, um lojista
# se auto-concede cortesia/ativa e burla cobrança. SERVER-ONLY: nunca use prefixo
# NEXT_PUBLIC_ (seguranca.md §7), nunca commite o valor real. Ausente/vazio =
# fail-closed: TODAS as ações administrativas são recusadas (inclusive p/ o admin).
SAAS_ADMIN_USER_ID=
